{
    "name": "sympress/demo",
    "type": "project",
    "description": "Reference WordPress website demonstrating structured development with SymPress and Symfony components.",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "johnpbloch/wordpress": "^7.0.0",
        "sympress/assets": "dev-main",
        "sympress/demo-base-mu-plugins": "dev-main",
        "sympress/demo-plugin": "dev-main",
        "sympress/event-dispatcher": "dev-main",
        "sympress/kernel": "dev-main",
        "sympress/migration": "dev-main",
        "sympress/monolog-bundle": "dev-main",
        "sympress/wp-cli-console": "dev-main",
        "wecodemore/wpstarter": "^3.0.1",
        "wp-cli/wp-cli-bundle": "^2.12.0",
        "wpackagist-theme/twentytwentyfive": "^1.5.0"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5",
        "symfony/var-dumper": "^8.0",
        "sympress/coding-standards": "dev-main",
        "sympress/profiler": "dev-main",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "extra": {
        "wordpress-install-dir": "public/wp",
        "wordpress-content-dir": "public/wp-content",
        "wpstarter": "dev-ops/wpstarter.json",
        "installer-paths": {
            "public/wp-content/mu-plugins/{$name}": [
                "type:wordpress-muplugin"
            ],
            "public/wp-content/plugins/{$name}": [
                "type:wordpress-plugin"
            ],
            "public/wp-content/themes/{$name}": [
                "type:wordpress-theme"
            ]
        },
        "sympress.asset-compiler": {
            "auto-run": true,
            "package-manager": "npm"
        },
        "sympress": {
            "public_components_demonstrated": [
                "sympress/kernel",
                "sympress/event-dispatcher",
                "sympress/migration",
                "sympress/assets",
                "sympress/wp-cli-console",
                "sympress/monolog-bundle",
                "sympress/profiler",
                "sympress/coding-standards"
            ]
        }
    },
    "scripts": {
        "cleanup": "rm -rf ./public/wp/wp-content",
        "compile-assets": [
            "Composer\\Config::disableProcessTimeout",
            "cd packages/sympress-demo && npm install",
            "cd packages/sympress-demo && npm run build"
        ],
        "post-install-cmd": [
            "@cleanup",
            "@compile-assets"
        ],
        "post-update-cmd": [
            "@cleanup",
            "@compile-assets"
        ],
        "demo:seed": [
            "wp plugin activate sympress-demo",
            "wp sympress-demo:create-notes --set=quotes --count=18 --reset"
        ],
        "qa:validate": "composer validate --strict --no-check-publish",
        "qa:audit": "composer audit --locked --no-interaction",
        "cs": [
            "cd packages/base-mu-plugins && ../../vendor/bin/phpcs --standard=phpcs.xml.dist",
            "cd packages/sympress-demo && ../../vendor/bin/phpcs --standard=phpcs.xml.dist"
        ],
        "static-analysis": [
            "cd packages/base-mu-plugins && ../../vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=1G --no-progress",
            "cd packages/sympress-demo && ../../vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=1G --no-progress"
        ],
        "test": "cd packages/sympress-demo && ../../vendor/bin/phpunit -c phpunit.xml.dist --no-coverage",
        "qa": [
            "@qa:validate",
            "@qa:audit",
            "@cs",
            "@static-analysis",
            "@test",
            "@qa:runtime"
        ],
        "qa:runtime": "vendor/bin/wp eval-file bin/runtime-smoke.php"
    },
    "config": {
        "classmap-authoritative": true,
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.5"
        },
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "johnpbloch/wordpress-core-installer": true,
            "phpstan/extension-installer": true,
            "wecodemore/wpstarter": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "./packages/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        }
    ]
}
